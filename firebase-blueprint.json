{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A booking for a transport service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "heure": { "type": "string" },
        "montant": { "type": "number" },
        "sieges": { "type": "number" },
        "valises": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nom", "whatsapp", "type", "montant", "status"]
    },
    "TouristSite": {
      "title": "TouristSite",
      "description": "A tourist destination in Senegal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "img": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "desc", "img"]
    },
    "ServiceItem": {
      "title": "ServiceItem",
      "description": "A service offered by ElleDrives",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "icon": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "price": { "type": "string" }
      },
      "required": ["id", "title", "desc", "price"]
    },
    "ReviewItem": {
      "title": "ReviewItem",
      "description": "A customer review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "meta": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["id", "name", "text", "rating"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings and content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prices": { "type": "object" },
        "services": { "type": "array", "items": { "$ref": "ServiceItem" } },
        "reviews": { "type": "array", "items": { "$ref": "ReviewItem" } },
        "heroImage": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "logo": { "type": "string" },
        "founderPhoto": { "type": "string" },
        "tiktokName": { "type": "string" }
      }
    }
  },
  "firestore": {
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of all transport bookings"
    },
    "tourisme/{siteId}": {
      "schema": "TouristSite",
      "description": "Collection of tourist sites"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings"
    }
  }
}
