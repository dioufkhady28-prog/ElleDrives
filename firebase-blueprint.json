{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A booking for a transport service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "heure": { "type": "string" },
        "montant": { "type": "number" },
        "sieges": { "type": "number" },
        "valises": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nom", "whatsapp", "type", "montant", "status"]
    },
    "TouristSite": {
      "title": "TouristSite",
      "description": "A tourist destination in Senegal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "img": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "desc", "img"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of all transport bookings"
    },
    "tourisme/{siteId}": {
      "schema": "TouristSite",
      "description": "Collection of tourist sites"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
